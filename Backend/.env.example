PORT=8000
NODE_ENV=development

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=investment_options
MYSQL_CREATE_DATABASE=true
MYSQL_SSL=false
# For Aiven, paste the full CA certificate text with \n line breaks:
# MYSQL_SSL_CA=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----

JWT_SECRET=replace-with-a-long-random-secret
CORS_ORIGINS=http://localhost:4200,https://YOUR-NETLIFY-SITE.netlify.app
